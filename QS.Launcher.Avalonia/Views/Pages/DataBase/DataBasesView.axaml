<UserControl x:Class="QS.Launcher.Views.Pages.DataBasesView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:QS.Launcher.ViewModels.PageViewModels;assembly=QS.Launcher"
             xmlns:vmdb="clr-namespace:QS.Launcher.ViewModels.PageViewModels.DataBase;assembly=QS.Launcher"
             xmlns:dbm="clr-namespace:QS.DbManagement;assembly=QS.DbManagement"
             d:DesignHeight="650"
             d:DesignWidth="450"
             x:DataType="vmdb:DataBasesVM"
             mc:Ignorable="d">
    <ScrollViewer>
        <Grid Margin="20" VerticalAlignment="Center" RowDefinitions="Auto, Auto, Auto, Auto">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Margin="5,0,0,0" HorizontalAlignment="Stretch" Content="Выберите базу данных:" />
			<Button Grid.Row="0" Grid.Column="1" Margin="0,0,5,0" HorizontalAlignment="Right" Command="{Binding OpenCreateDatabaseCommand}" IsVisible="{Binding CanCreateDatabase}" Content="Создать базу данных" />
            <ListBox x:Name="databases" Grid.ColumnSpan="2" Grid.Row="1" Margin="5" HorizontalAlignment="Stretch" 
                ItemsSource="{Binding Databases}"
                SelectedItem="{Binding SelectedDatabase}"
                DoubleTapped="Databases_OnDoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="dbm:DbInfo">
                        <DockPanel MaxHeight="30" HorizontalAlignment="Stretch">
                            <Button DockPanel.Dock="Right" Margin="4,0,0,0" Padding="8,0" VerticalAlignment="Center"
                                    Background="Transparent" BorderThickness="0" FontWeight="Bold" Content="⋮"
                                    IsVisible="{Binding $parent[ListBox].((vmdb:DataBasesVM)DataContext).CanManageDatabases}">
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="Сделать резервную копию" Click="BackupDatabase_OnClick"
											IsVisible="{Binding $parent[ListBox].((vmdb:DataBasesVM)DataContext).CanBackupDatabase}" />
                                        <MenuItem Header="Удалить базу" Click="DeleteDatabase_OnClick"
											IsVisible="{Binding $parent[ListBox].((vmdb:DataBasesVM)DataContext).CanDropDatabase}" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Label DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" VerticalContentAlignment="Center" Content="{Binding Version}" />
                            <Label Content="{Binding Title}" />
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
	            <ListBox.KeyBindings>
		            <KeyBinding Gesture="Enter" Command="{Binding ConnectCommand}" />
	            </ListBox.KeyBindings>
            </ListBox>

            <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto">
                <Button IsDefault="True" Margin="5" HorizontalAlignment="Stretch" Command="{Binding ConnectCommand}" Content="Запустить" />

	            <Button Grid.Column="1" Margin="5" HorizontalAlignment="Stretch" Command="{Binding PreviousPageCommand}" Content="Назад" />

	            <CheckBox Grid.Row="1" Grid.ColumnSpan="2" Margin="5" Content="Не закрывать лаунчер после подключения" Foreground="#7A000000" 
	                      IsChecked="{Binding !ShouldCloseLauncherAfterStart}" 
	                      IsVisible="{Binding VisibleShouldCloseLauncherCheckBox}" />

	            <StackPanel x:Name="loadingPanel" Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" IsVisible="False" Orientation="Horizontal">
                    <Label Margin="5" Content="Запуск..." />
                    <Image x:Name="cogwheel" Height="32" Source="avares://QS.Launcher.Avalonia/Assets/cogwheel.ico">
                        <Image.Transitions>
                            <Transitions>
                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:4.00" />
                            </Transitions>
                        </Image.Transitions>
                        <Image.Styles>
                            <Style Selector="Image">
                                <Setter Property="RenderTransform" Value="rotate(0deg)" />
                            </Style>
                            <Style Selector="Image.rolled">
                                <Setter Property="RenderTransform" Value="rotate(720deg)" />
                            </Style>
                        </Image.Styles>
                    </Image>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" IsVisible="{Binding IsAdmin}">
                    <Grid ColumnDefinitions="*, Auto, *">
                        <Separator Grid.Column="0" />

                        <Label Grid.Column="1" Margin="5" HorizontalAlignment="Center" Content="Администрирование" PointerPressed="Label_PointerPressed">
                            <Label.Styles>
                                <Style Selector="Label:pointerover">
                                    <Setter Property="Foreground" Value="Blue" />
                                </Style>
                                <Style Selector="Label">
                                    <Setter Property="Foreground" Value="#7A000000" />
                                </Style>
                            </Label.Styles>
                        </Label>

                        <Separator Grid.Column="2" />
                    </Grid>

                    <StackPanel x:Name="adminPanel" Classes="animated invisible">
                        <Button Margin="5" HorizontalAlignment="Stretch" Command="{Binding NextPageCommand}" Content="Управление пользователями" />

                        <StackPanel.Styles>
                            <Style Selector="StackPanel.invisible">
                                <Setter Property="Opacity" Value="0" />
                                <Setter Property="RenderTransform" Value="translateY(-90px)" />
                                <Setter Property="IsHitTestVisible" Value="False" />
                            </Style>
                        </StackPanel.Styles>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
